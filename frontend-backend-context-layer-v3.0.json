{
  "version": "3.0",
  "design_system": {
    "id": "betafits_design_authority_v1.1",
    "name": "Betafits Design Authority v1.1",
    "created_by": "Fahad - UX Designer",
    "dated": "24 Feb 2026",
    "base": "Tailwind Scale + shadcn Structure",
    "mode": "Light Only",
    "style": "Neutral SaaS, Medium Soft Rounded",
    "core_principles": [
      "Clean neutral SaaS aesthetic",
      "Brand expressed only through primary color",
      "Neutral UI surfaces",
      "Medium-soft rounded corners",
      "Minimal shadows, clear separation through stroke",
      "8px spacing grid only",
      "Strict token discipline — no custom inline values",
      "Clear visual hierarchy using contrast, not decoration",
      "Accessible contrast for text and states"
    ],
    "colors": {
      "primary": {
        "50": "#F4F8EC",
        "100": "#E6F0D7",
        "200": "#CFE1AE",
        "300": "#B8D285",
        "400": "#A5C66C",
        "500": "#94BA5A",
        "600": "#7EA246",
        "700": "#688733",
        "800": "#526B25",
        "900": "#3B4D19",
        "usage": {
          "button": "500",
          "hover": "600",
          "focus_ring": "300",
          "subtle_bg": "50"
        }
      },
      "neutral": {
        "50": "#FAFAFA",
        "100": "#F4F4F5",
        "200": "#E4E4E7",
        "300": "#D4D4D8",
        "400": "#A1A1AA",
        "500": "#71717A",
        "600": "#52525B",
        "700": "#3F3F46",
        "800": "#27272A",
        "900": "#18181B",
        "950": "#111111",
        "usage": {
          "app_background": "50",
          "section_background": "#FFFFFF",
          "subtle_section": "100",
          "card_background": "#FFFFFF",
          "border_default": "200",
          "strong_divider": "300"
        }
      },
      "semantic": {
        "success": { "500": "#22C55E", "bg": "#DCFCE7" },
        "error": { "500": "#EF4444", "bg": "#FEE2E2" },
        "warning": { "500": "#F59E0B", "bg": "#FEF3C7" },
        "info": { "500": "#3B82F6", "bg": "#DBEAFE" }
      }
    },
    "border": {
      "default": "1px solid neutral-200",
      "interactive_focus": "1px solid primary-500",
      "error": "1px solid #EF4444"
    },
    "typography": {
      "font": "Inter",
      "h1": { "size": "28px", "weight": "600", "line_height": "1.3" },
      "h2": { "size": "22px", "weight": "600", "line_height": "1.35" },
      "h3": { "size": "18px", "weight": "600" },
      "body": { "size": "14px", "weight": "400", "line_height": "1.6" },
      "small": { "size": "12px", "weight": "400" },
      "label": { "size": "13px", "weight": "500" },
      "text_colors": {
        "primary": "neutral-900",
        "secondary": "neutral-600",
        "muted": "neutral-500",
        "disabled": "neutral-400"
      }
    },
    "spacing": {
      "base_unit": "8px",
      "allowed": [8, 16, 24, 32, 40, 48, 64],
      "card_padding": "24px",
      "section_spacing": "32px",
      "page_horizontal_padding": "32px",
      "form_field_spacing": "16px",
      "label_to_input": "8px"
    },
    "border_radius": {
      "small": "6px",
      "medium": "10px",
      "large": "14px",
      "usage": {
        "buttons": "medium",
        "inputs": "medium",
        "cards": "large",
        "badges": "small",
        "modals": "large"
      }
    },
    "shadows": {
      "card": "0 1px 2px rgba(0,0,0,0.05)",
      "elevated": "0 4px 6px rgba(0,0,0,0.08)",
      "modal": "0 10px 25px rgba(0,0,0,0.15)"
    },
    "components": {
      "buttons": {
        "height": "40px",
        "padding_horizontal": "16px",
        "radius": "medium",
        "primary": { "bg": "primary-500", "text": "white", "hover": "primary-600" },
        "secondary": { "bg": "white", "border": "neutral-300", "text": "neutral-900" },
        "disabled": { "bg": "neutral-200", "text": "neutral-400" }
      },
      "inputs": {
        "height": "40px",
        "radius": "medium",
        "border": "neutral-300",
        "focus_border": "primary-500",
        "focus_ring": "2px primary-300"
      },
      "cards": {
        "bg": "white",
        "border": "neutral-200",
        "radius": "large",
        "padding": "24px",
        "shadow": "card"
      },
      "badges": {
        "height": "24px",
        "padding_horizontal": "8px",
        "radius": "small"
      }
    },
    "not_allowed": [
      "Gradients",
      "Glassmorphism",
      "Random drop shadows",
      "Custom hex values outside tokens",
      "Additional font sizes",
      "Arbitrary spacing values",
      "Decorative outlines"
    ],
    "ai_instruction": "Use Betafits Design Authority v1.1. Follow all token definitions for color, neutral scale, spacing, border, stroke, typography, and layout rules. Do not introduce new styling values."
  },
